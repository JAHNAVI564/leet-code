class Solution {
public:
    vector<int> inorderTraversal(TreeNode* root) {
        vector<int> res;
        stack<TreeNode*> st;
        TreeNode* curr = root;

        while (curr != nullptr || !st.empty()) {
            // Go to the leftmost node
            while (curr != nullptr) {
                st.push(curr);
                curr = curr->left;
            }
            // Pop the node and add it to result
            curr = st.top();
            st.pop();
            res.push_back(curr->val);
            // Visit right subtree
            curr = curr->right;
        }

        return res;
    }
};
