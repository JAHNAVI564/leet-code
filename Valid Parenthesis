class Solution:
    def isValid(self, s: str) -> bool:
        stack = []
        # Mapping of closing to opening brackets
        pairs = {')': '(', '}': '{', ']': '['}

        for char in s:
            if char in pairs.values():
                # If it's an opening bracket, push to stack
                stack.append(char)
            elif char in pairs:
                # If it's a closing bracket, stack must not be empty and top must match
                if not stack or stack.pop() != pairs[char]:
                    return False
            else:
                # Invalid character (not required in problem, but safe)
                return False

        # If stack is empty, all brackets matched correctly
        return not stack
