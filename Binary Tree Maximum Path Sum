class Solution:
    def maxPathSum(self, root: Optional[TreeNode]) -> int:
        self.max_sum = float('-inf')
        
        def dfs(node):
            if not node:
                return 0
            
            # Ignore negative paths
            left = max(dfs(node.left), 0)
            right = max(dfs(node.right), 0)
            
            # Path that passes through this node (including both children)
            current_path = node.val + left + right
            
            # Update the global max path sum
            self.max_sum = max(self.max_sum, current_path)
            
            # Return the max gain if continue the same path (only one child can be included)
            return node.val + max(left, right)
        
        dfs(root)
        return self.max_sum
