class Solution {
public:
    ListNode* mergeTwoLists(ListNode* list1, ListNode* list2) {
        // Create a dummy node to simplify the logic.
        ListNode* dummy = new ListNode();
        ListNode* current = dummy;
        
        // Pointers to traverse through the two lists
        ListNode* p1 = list1;
        ListNode* p2 = list2;
        
        // Traverse both lists and add the smaller node to the merged list
        while (p1 != nullptr && p2 != nullptr) {
            if (p1->val <= p2->val) {
                current->next = p1;
                p1 = p1->next;
            } else {
                current->next = p2;
                p2 = p2->next;
            }
            current = current->next; // Move the current pointer forward
        }
        
        // Once one list is exhausted, attach the remaining nodes of the other list
        if (p1 != nullptr) {
            current->next = p1;
        } else {
            current->next = p2;
        }
        
        // Return the merged list starting from the next node of the dummy
        return dummy->next;
    }
};
