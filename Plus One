#include <vector>
using namespace std;

class Solution {
public:
    vector<int> plusOne(vector<int>& digits) {
        int n = digits.size();
        
        // Start from the last digit
        for (int i = n - 1; i >= 0; --i) {
            if (digits[i] < 9) {
                digits[i]++;
                return digits;  // No carry-over needed
            }
            digits[i] = 0;  // Set the current digit to 0, carry over the 1
        }
        
        // If we reached here, it means we need to add a '1' at the front
        digits.insert(digits.begin(), 1);
        return digits;
    }
};
