class Solution {
public:
    int mySqrt(int x) {
        if (x == 0 || x == 1) return x;  // Handle edge cases for 0 and 1

        long long left = 0, right = x;  // Use long long for left and right to avoid overflow

        while (left <= right) {
            long long mid = left + (right - left) / 2;  // To avoid overflow

            long long midSquared = mid * mid;  // Use long long for multiplication to avoid overflow

            if (midSquared == x) {
                return mid;  // Found the exact square root
            }
            else if (midSquared < x) {
                left = mid + 1;  // We need to search in the right half
            }
            else {
                right = mid - 1;  // We need to search in the left half
            }
        }

        // When the loop exits, right is the largest value such that right^2 <= x
        return right;
    }
};
