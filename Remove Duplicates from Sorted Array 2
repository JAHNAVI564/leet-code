class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int n = nums.size();
        if (n <= 2) return n;  // All elements can stay if length <= 2
        
        int i = 2;  // Start placing from the 3rd position
        for (int j = 2; j < n; ++j) {
            if (nums[j] != nums[i - 2]) {
                nums[i] = nums[j];
                i++;
            }
        }
        return i;  // New length of array with duplicates allowed twice
    }
};
