class Solution {
public:
    string simplifyPath(string path) {
        vector<string> stack;
        string dir;
        stringstream ss(path);

        // Split the path by '/'
        while (getline(ss, dir, '/')) {
            if (dir == "" || dir == ".") {
                continue;
            } else if (dir == "..") {
                if (!stack.empty()) stack.pop_back();  // Go up one level
            } else {
                stack.push_back(dir);  // Valid directory
            }
        }

        // Rebuild canonical path
        string result = "/";
        for (int i = 0; i < stack.size(); ++i) {
            result += stack[i];
            if (i != stack.size() - 1) result += "/";
        }

        return result;
    }
};
