class Solution {
public:
    vector<string> fullJustify(vector<string>& words, int maxWidth) {
        vector<string> result;
        vector<string> currentLine;
        int currentLength = 0;  // Tracks the total length of words in the current line

        for (const string& word : words) {
            // If adding the next word would exceed maxWidth
            if (currentLength + currentLine.size() + word.length() > maxWidth) {
                // Justify the current line
                result.push_back(justifyLine(currentLine, currentLength, maxWidth, false));
                // Start a new line with the current word
                currentLine = {word};
                currentLength = word.length();
            } else {
                // Add the word to the current line
                currentLine.push_back(word);
                currentLength += word.length();
            }
        }
        
        // Last line should be left justified
        result.push_back(justifyLine(currentLine, currentLength, maxWidth, true));

        return result;
    }

private:
    string justifyLine(const vector<string>& words, int totalLength, int maxWidth, bool isLastLine) {
        int numWords = words.size();
        if (numWords == 1 || isLastLine) {
            // For the last line or a single word, just left justify
            string result = words[0];
            for (int i = 1; i < numWords; ++i) {
                result += " " + words[i];
            }
            result += string(maxWidth - result.length(), ' ');  // Add trailing spaces
            return result;
        }

        // Calculate the total number of spaces to distribute
        int totalSpaces = maxWidth - totalLength;
        int spacesBetweenWords = totalSpaces / (numWords - 1);  // Minimum spaces between words
        int extraSpaces = totalSpaces % (numWords - 1);  // Extra spaces to distribute from left to right

        string result = words[0];
        // Add spaces between words
        for (int i = 1; i < numWords; ++i) {
            int spaceCount = spacesBetweenWords + (i <= extraSpaces ? 1 : 0);  // Extra space if necessary
            result += string(spaceCount, ' ') + words[i];
        }

        return result;
    }
};
