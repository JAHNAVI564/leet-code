#include <vector>
#include <algorithm>
using namespace std;

class Solution {
public:
    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        vector<vector<int>> results;
        vector<int> combination;
        sort(candidates.begin(), candidates.end());  // optional, for optimization
        backtrack(candidates, target, 0, combination, results);
        return results;
    }

private:
    void backtrack(const vector<int>& candidates, int target, int start,
                   vector<int>& combination, vector<vector<int>>& results) {
        if (target == 0) {
            results.push_back(combination);
            return;
        }

        for (int i = start; i < (int)candidates.size(); ++i) {
            if (candidates[i] > target) {
                // since candidates are sorted, no need to continue further
                break;
            }
            combination.push_back(candidates[i]);
            // not i + 1 because we can reuse same element unlimited times
            backtrack(candidates, target - candidates[i], i, combination, results);
            combination.pop_back();
        }
    }
};
