class Solution {
public:
    int uniquePaths(int m, int n) {
        // We will calculate the combination C(m + n - 2, m - 1)
        long long result = 1;
        int k = min(m - 1, n - 1);  // to optimize, take the smaller of m-1 or n-1

        // Calculate the combination C(m + n - 2, k)
        for (int i = 1; i <= k; i++) {
            result = result * (m + n - 2 - (k - i)) / i;
        }

        return (int)result;
    }
};
